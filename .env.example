# ===========================================
# Hospital API — Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=3000

# Database (PostgreSQL) — optional, in-memory for demo
DB_HOST=localhost
DB_PORT=5432
DB_USER=hospital
DB_PASSWORD=CHANGE_ME
DB_NAME=hospital_db

# JWT Secret — REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET
JWT_EXPIRY_HOURS=72

# CORS — comma-separated origins, or * for all
ALLOWED_ORIGINS=https://dash.zuhudo.cc.cd,https://zuhudo.cc.cd
